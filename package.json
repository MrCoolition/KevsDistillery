{
  "name": "data-source-discovery-distillery",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "ng": "node ./node_modules/@angular/cli/bin/ng.js",
    "start": "node ./scripts/dev.mjs",
    "start:ui": "node ./node_modules/@angular/cli/bin/ng.js serve --proxy-config proxy.conf.json",
    "start:api": "node ./scripts/dev-api.mjs",
    "build": "node ./node_modules/@angular/cli/bin/ng.js build",
    "watch": "node ./node_modules/@angular/cli/bin/ng.js build --watch --configuration development",
    "test": "node ./node_modules/@angular/cli/bin/ng.js test",
    "db:migrate": "node ./scripts/migrate-neon.mjs",
    "typecheck:api": "tsc -p tsconfig.api.json --noEmit",
    "check": "npm run build && npm run typecheck:api"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@neondatabase/serverless": "^1.1.0",
    "cfb": "^1.2.2",
    "csv-parse": "^6.2.1",
    "exceljs": "^4.4.0",
    "formidable": "^3.5.4",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "openai": "^6.36.0",
    "pdfkit": "^0.18.0",
    "rxjs": "~7.8.0",
    "sql-formatter": "^15.7.3",
    "tslib": "^2.3.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@angular/build": "^21.2.10",
    "@angular/cli": "^21.2.10",
    "@angular/compiler-cli": "^21.2.0",
    "@types/formidable": "^3.5.1",
    "@types/node": "^25.6.0",
    "@types/pdfkit": "^0.17.6",
    "@vercel/node": "^5.7.15",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
