# Copy to .env.local for local development. Never commit .env.local.
# In Vercel, set these in Project Settings > Environment Variables.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DATABASE?sslmode=require"
OPENAI_API_KEY="sk-your-server-side-key"
OPENAI_MODEL="gpt-5.5"
# Optional: override token pricing used for the UI cost estimate.
# Values are USD per 1M tokens. Keep this updated if your OpenAI pricing differs.
OPENAI_PRICING_JSON='{"gpt-5.5":{"inputPerMillion":5,"cachedInputPerMillion":0.5,"outputPerMillion":30}}'
DISCOVERY_PACKAGE_VERSION="1.0.0"
# Optional local-only override. Default local upload temp storage is outside OneDrive in the OS temp folder.
# DISCOVERY_UPLOAD_DIR="C:\\Temp\\data-source-discovery-distillery\\uploads"
