{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "isolatedModules": false,
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "strict": false,
    "noImplicitAny": false,
    "noPropertyAccessFromIndexSignature": false,
    "noImplicitReturns": false,
    "types": ["node"]
  },
  "include": ["api/**/*.ts"]
}
